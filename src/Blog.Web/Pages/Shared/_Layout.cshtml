<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Devof.NET</title>
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "A community of developers sharing knowledge, building together.")" />
    <meta name="keywords" content="@(ViewData["MetaKeywords"] ?? "programming, development, .NET, C#, tutorials")" />
    
    <!-- Open Graph -->
    <meta property="og:title" content="@ViewData["Title"] - Devof.NET" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "A community of developers sharing knowledge.")" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@(ViewData["OgImage"] ?? "/images/og-default.png")" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <!-- Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-container">
        <!-- Navigation -->
        <header class="navbar">
            <div class="navbar-container">
                <div class="navbar-left">
                    <a href="/" class="navbar-brand">
                        <span class="brand-icon">⚡</span>
                        <span class="brand-text">Devof<span class="brand-accent">.NET</span></span>
                    </a>
                    <div class="search-container">
                        <form action="/Search" method="get" class="search-form">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" name="q" placeholder="Search..." class="search-input" />
                        </form>
                    </div>
                </div>
                
                <nav class="navbar-center">
                    <a href="/" class="nav-link">Home</a>
                    <a href="/Tag" class="nav-link">Tags</a>
                    <a href="/?feed=trending" class="nav-link">Trending</a>
                </nav>
                
                <div class="navbar-right">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Post/Create" class="btn btn-primary btn-create">
                            <i class="fas fa-pen"></i>
                            <span>Create Post</span>
                        </a>
                        <div class="dropdown">
                            <button class="dropdown-toggle user-menu" id="userDropdown">
                                <img src="@(User.FindFirst("AvatarUrl")?.Value ?? "/images/default-avatar.png")" 
                                     alt="@User.Identity.Name" class="user-avatar" />
                            </button>
                            <div class="dropdown-menu dropdown-menu-right" id="userDropdownMenu">
                                <a href="/Author/@User.Identity.Name" class="dropdown-item">
                                    <i class="fas fa-user"></i> Profile
                                </a>
                                <a href="/Settings/Bookmarks" class="dropdown-item">
                                    <i class="fas fa-bookmark"></i> Bookmarks
                                </a>
                                <a href="/Settings" class="dropdown-item">
                                    <i class="fas fa-cog"></i> Settings
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("Moderator"))
                                {
                                    <hr class="dropdown-divider" />
                                    <a href="/Admin" class="dropdown-item">
                                        <i class="fas fa-shield-alt"></i> Admin Panel
                                    </a>
                                }
                                <hr class="dropdown-divider" />
                                <form method="post" asp-page="/Account/Logout">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fas fa-sign-out-alt"></i> Logout
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-outline">Login</a>
                        <a href="/Account/Register" class="btn btn-primary">Sign Up</a>
                    }
                    <button class="theme-toggle" id="themeToggle" title="Toggle dark mode">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="main-content">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="footer">
            <div class="footer-container">
                <div class="footer-brand">
                    <span class="brand-icon">⚡</span>
                    <span>Devof<span class="brand-accent">.NET</span></span>
                </div>
                <div class="footer-links">
                    <a href="/About">About</a>
                    <a href="/Contact">Contact</a>
                    <a href="/Privacy">Privacy</a>
                    <a href="/Terms">Terms</a>
                </div>
                <div class="footer-social">
                    <a href="#" aria-label="GitHub"><i class="fab fa-github"></i></a>
                    <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
                    <a href="#" aria-label="Discord"><i class="fab fa-discord"></i></a>
                </div>
                <p class="footer-copyright">© @DateTime.Now.Year Devof.NET. Built with ❤️ and .NET</p>
            </div>
        </footer>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
