<style>
.static-page {
    max-width: 900px;
    margin: 0 auto;
}

.terms-content {
    font-size: 0.9375rem;
    line-height: 1.8;
}

.terms-content section {
    margin-bottom: 2.5rem;
}

.terms-content h2 {
    font-size: 1.5rem;
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--color-text);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.5rem;
}

.terms-content h3 {
    font-size: 1.125rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
}

.terms-content p,
.terms-content li {
    color: var(--color-text-secondary);
}

.terms-content ul {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
}

.terms-content li {
    margin-bottom: 0.5rem;
}

.legal-notice {
    background: rgba(245, 158, 11, 0.1);
    border-left: 4px solid var(--color-warning);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    margin: 1rem 0;
}

.legal-notice p {
    font-weight: 500;
    font-size: 0.875rem;
}

.acknowledgment {
    background: var(--color-primary-light);
    border: 2px solid var(--color-primary);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    margin-top: 2rem;
    text-align: center;
}

.acknowledgment p {
    margin: 0;
    color: var(--color-primary);
    font-size: 1rem;
}
</style>
