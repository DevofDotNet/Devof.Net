@page
@model Blog.Web.Pages.SearchModel
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Q) ? "Search" : $"Search: {Model.Q}";
}

<div class="search-page">
    <div class="page-header">
        <h1 class="page-title">
            @if (string.IsNullOrWhiteSpace(Model.Q))
            {
                <text>Search Posts</text>
            }
            else
            {
                <text>Search Results for "@Model.Q"</text>
            }
        </h1>
        @if (!string.IsNullOrWhiteSpace(Model.Q))
        {
            <p class="page-subtitle">Found @Model.Results.TotalCount result(s)</p>
        }
    </div>

    <form method="get" class="search-form-page">
        <div class="search-input-wrapper">
            <i class="fas fa-search search-icon"></i>
            <input type="text" name="q" value="@Model.Q" placeholder="Search for posts..." class="search-input-large"
                autofocus />
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.Q))
    {
        @if (Model.Results.Items.Any())
        {
            <div class="posts-grid">
                @foreach (var post in Model.Results.Items)
                {
                    <article class="card post-card animate-slide-up">
                        @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                        {
                            <img src="@post.CoverImageUrl" alt="@post.Title" class="post-card-cover" loading="lazy" />
                        }
                        <div class="post-card-content">
                            <div class="post-card-author">
                                <img src="@(post.Author.AvatarUrl ?? "/images/default-avatar.png")"
                                    alt="@post.Author.DisplayName" />
                                <div class="post-card-author-info">
                                    <a href="/Author/@post.Author.UserName" class="post-card-author-name">
                                        @(post.Author.DisplayName ?? post.Author.UserName)
                                    </a>
                                    <span class="post-card-date">
                                        @post.PublishedAt?.ToString("MMM dd, yyyy")
                                    </span>
                                </div>
                            </div>

                            <a href="/post/@post.Slug" class="post-card-title">
                                @post.Title
                            </a>

                            <p class="post-card-excerpt">@post.Excerpt</p>

                            <div class="post-card-tags">
                                @foreach (var tag in post.Tags.Take(3))
                                {
                                    <a href="/Tag/@tag.Slug" class="tag"
                                        style="@(tag.Color != null ? $"background: {tag.Color}20; color: {tag.Color};" : "")">
                                        #@tag.Name
                                    </a>
                                }
                            </div>

                            <div class="post-card-meta">
                                <div class="post-card-stats">
                                    <span class="post-stat">
                                        <i class="fas fa-heart @(post.IsLiked ? "text-danger" : "")"></i>
                                        @post.LikeCount
                                    </span>
                                    <span class="post-stat">
                                        <i class="fas fa-comment"></i>
                                        @post.CommentCount
                                    </span>
                                </div>
                                <span class="post-reading-time">
                                    @post.ReadingTimeMinutes min read
                                </span>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <!-- Pagination -->
            @if (Model.Results.TotalPages > 1)
            {
                <nav class="pagination">
                    @if (Model.Results.HasPreviousPage)
                    {
                        <a href="/Search?q=@Model.Q&page=@(Model.Results.Page - 1)" class="pagination-link">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    }

                    @for (var i = 1; i <= Model.Results.TotalPages && i <= 5; i++)
                    {
                        <a href="/Search?q=@Model.Q&page=@i" class="pagination-link @(i == Model.Results.Page ? "active" : "")">
                            @i
                        </a>
                    }

                    @if (Model.Results.HasNextPage)
                    {
                        <a href="/Search?q=@Model.Q&page=@(Model.Results.Page + 1)" class="pagination-link">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                </nav>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon">🔍</div>
                <h3 class="empty-state-title">No results found</h3>
                <p class="empty-state-description">Try different keywords or check your spelling</p>
            </div>
        }
    }
</div>

<style>
    .search-page {
        max-width: 1200px;
        margin: 0 auto;
    }

    .search-form-page {
        margin: var(--spacing-2xl) 0;
    }

    .search-input-wrapper {
        display: flex;
        gap: var(--spacing-md);
        max-width: 600px;
        margin: 0 auto;
    }

    .search-input-large {
        flex: 1;
        padding: var(--spacing-md) var(--spacing-lg) var(--spacing-md) 3rem;
        background: var(--color-bg-elevated);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        font-size: 1rem;
        color: var(--color-text);
        transition: all var(--transition-normal);
    }

    .search-input-large:focus {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px var(--color-primary-light);
    }

    .search-input-wrapper {
        position: relative;
    }

    .search-input-wrapper .search-icon {
        position: absolute;
        left: var(--spacing-lg);
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-text-muted);
    }

    .animate-slide-up {
        animation: slideUp 0.3s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
