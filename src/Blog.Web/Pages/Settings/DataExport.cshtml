@page
@model Blog.Web.Pages.Settings.DataExportModel
@{
    ViewData["Title"] = "Export My Data";
}

<div class="settings-page">
    <div class="settings-container">
        <h1 class="page-title">Export My Data</h1>

        <div class="settings-card card">
            <div class="card-body">
                <div class="settings-tabs">
                    <a href="/Settings/Profile" class="tab-btn">
                        <i class="fas fa-user"></i> Profile
                    </a>
                    <a href="/Settings/Account" class="tab-btn">
                        <i class="fas fa-lock"></i> Account
                    </a>
                    <a href="/Settings/Drafts" class="tab-btn">
                        <i class="fas fa-file-alt"></i> Drafts
                    </a>
                    <a href="/Settings/DataExport" class="tab-btn active">
                        <i class="fas fa-download"></i> Data Export
                    </a>
                </div>

                <div class="export-section">
                    <div class="export-info">
                        <h2><i class="fas fa-shield-alt"></i> Your Data, Your Right</h2>
                        <p>
                            Under GDPR and similar privacy regulations, you have the right to download a copy of your personal data.
                            This export includes:
                        </p>
                        <ul>
                            <li><i class="fas fa-user"></i> Your profile information</li>
                            <li><i class="fas fa-newspaper"></i> All your posts and their content</li>
                            <li><i class="fas fa-bookmark"></i> Your bookmarks</li>
                            <li><i class="fas fa-tags"></i> Tags you follow</li>
                        </ul>
                        <p class="text-muted">The data will be downloaded as a JSON file.</p>
                    </div>

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-download"></i> Download My Data
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .export-section { margin-top: var(--spacing-xl); }
    .export-info {
        margin-bottom: var(--spacing-xl);
    }
    .export-info h2 {
        font-size: 1.25rem;
        margin-bottom: var(--spacing-md);
    }
    .export-info ul {
        list-style: none;
        padding: 0;
        margin: var(--spacing-md) 0;
    }
    .export-info li {
        padding: var(--spacing-sm) 0;
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        color: var(--color-text-secondary);
    }
    .export-info li i {
        color: var(--color-primary);
        width: 20px;
    }
</style>
