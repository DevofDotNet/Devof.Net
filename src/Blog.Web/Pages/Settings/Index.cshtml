@page
@model Blog.Web.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<div class="settings-page">
    <div class="settings-container">
        <h1 class="page-title">Settings</h1>

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert-success">
                <i class="fas fa-check-circle"></i>
                @Model.StatusMessage
            </div>
        }

        <div class="settings-card card">
            <div class="card-body">
                <!-- Tab Navigation -->
                <div class="settings-tabs">
                    <button class="tab-btn @(Model.ActiveTab == "profile" ? "active" : "")" data-tab="profile">
                        <i class="fas fa-user"></i>
                        Profile
                    </button>
                    <button class="tab-btn @(Model.ActiveTab == "account" ? "active" : "")" data-tab="account">
                        <i class="fas fa-lock"></i>
                        Account
                    </button>
                </div>

                <!-- Profile Tab Content -->
                <div class="tab-content @(Model.ActiveTab == "profile" ? "active" : "")" id="profile-tab">
                    <form method="post" enctype="multipart/form-data" asp-page-handler="UpdateProfile">
                        <div asp-validation-summary="ModelOnly" class="validation-errors"></div>

                        <!-- ... (Avatar Section - matches existing structure) ... -->
                        <div class="avatar-section">
                            <div class="avatar-preview">
                                <img src="@(Model.Input.AvatarUrl ?? "/images/default-avatar.png")" alt="Profile Avatar"
                                    class="avatar-img" id="avatar-preview" />
                                <div class="avatar-overlay">
                                    <i class="fas fa-camera"></i>
                                </div>
                            </div>
                            <div class="avatar-upload-zone">
                                <h3>Profile Picture</h3>
                                <div class="upload-options">
                                    <div class="upload-file-wrapper">
                                        <input type="file" asp-for="Input.AvatarFile" id="avatar-file-input"
                                            accept="image/jpeg,image/png,image/gif" class="file-input-hidden" />
                                        <label for="avatar-file-input" class="upload-btn">
                                            <i class="fas fa-upload"></i>
                                            Upload Image
                                        </label>
                                        <span class="file-info" id="file-info">JPG, PNG, or GIF (max 5MB)</span>
                                    </div>
                                    <div class="or-divider">
                                        <span>OR</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Public Profile Section -->
                        <div class="form-section">
                            <h2 class="section-title">
                                <i class="fas fa-id-card"></i>
                                Public Profile
                            </h2>

                            <div class="form-group">
                                <label asp-for="Input.DisplayName" class="form-label">Display Name</label>
                                <input asp-for="Input.DisplayName" class="form-input" placeholder="Your display name" />
                                <span asp-validation-for="Input.DisplayName" class="form-error"></span>
                                <p class="form-hint">Your name as it appears on your profile and posts.</p>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.AvatarUrl" class="form-label">Profile Image URL</label>
                                <div class="input-icon-wrapper">
                                    <i class="fas fa-image input-icon"></i>
                                    <input asp-for="Input.AvatarUrl" class="form-input"
                                        placeholder="https://example.com/avatar.jpg" id="avatar-url-input" />
                                </div>
                                <span asp-validation-for="Input.AvatarUrl" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.Bio" class="form-label">Bio</label>
                                <textarea asp-for="Input.Bio" class="form-textarea" rows="4"
                                    placeholder="Tell us a little bit about yourself..."></textarea>
                                <span asp-validation-for="Input.Bio" class="form-error"></span>
                                <p class="form-hint">Brief description for your profile.</p>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.Location" class="form-label">Location</label>
                                <div class="input-icon-wrapper">
                                    <i class="fas fa-map-marker-alt input-icon"></i>
                                    <input asp-for="Input.Location" class="form-input" placeholder="Your location" />
                                </div>
                                <span asp-validation-for="Input.Location" class="form-error"></span>
                            </div>
                        </div>

                        <!-- Social Links Section -->
                        <div class="form-section">
                            <h2 class="section-title">
                                <i class="fas fa-share-alt"></i>
                                Social Links
                            </h2>

                            <div class="form-group">
                                <label asp-for="Input.WebsiteUrl" class="form-label">Website URL</label>
                                <div class="input-icon-wrapper">
                                    <i class="fas fa-globe input-icon"></i>
                                    <input asp-for="Input.WebsiteUrl" class="form-input"
                                        placeholder="https://yoursite.com" />
                                </div>
                                <span asp-validation-for="Input.WebsiteUrl" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.GitHubUrl" class="form-label">GitHub Profile</label>
                                <div class="input-icon-wrapper">
                                    <i class="fab fa-github input-icon"></i>
                                    <input asp-for="Input.GitHubUrl" class="form-input"
                                        placeholder="https://github.com/username" />
                                </div>
                                <span asp-validation-for="Input.GitHubUrl" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.TwitterUrl" class="form-label">Twitter Profile</label>
                                <div class="input-icon-wrapper">
                                    <i class="fab fa-twitter input-icon"></i>
                                    <input asp-for="Input.TwitterUrl" class="form-input"
                                        placeholder="https://twitter.com/username" />
                                </div>
                                <span asp-validation-for="Input.TwitterUrl" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.LinkedInUrl" class="form-label">LinkedIn Profile</label>
                                <div class="input-icon-wrapper">
                                    <i class="fab fa-linkedin input-icon"></i>
                                    <input asp-for="Input.LinkedInUrl" class="form-input"
                                        placeholder="https://linkedin.com/in/username" />
                                </div>
                                <span asp-validation-for="Input.LinkedInUrl" class="form-error"></span>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i>
                                Save Changes
                            </button>
                            <a href="/" class="btn btn-outline">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>

                <!-- Account Tab Content -->
                <div class="tab-content @(Model.ActiveTab == "account" ? "active" : "")" id="account-tab">
                    <form method="post" asp-page-handler="ChangePassword">
                        <div asp-validation-summary="ModelOnly" class="validation-errors"></div>

                        <div class="form-section">
                            <h2 class="section-title">
                                <i class="fas fa-lock"></i>
                                Security
                            </h2>

                            @if (Model.HasPassword)
                            {
                                <div class="form-group">
                                    <label asp-for="ChangePasswordInput.OldPassword" class="form-label">Current
                                        Password</label>
                                    <div class="input-icon-wrapper">
                                        <i class="fas fa-key input-icon"></i>
                                        <input asp-for="ChangePasswordInput.OldPassword" class="form-input" />
                                    </div>
                                    <span asp-validation-for="ChangePasswordInput.OldPassword" class="form-error"></span>
                                </div>
                            }
                            else
                            {
                                <div class="alert-info" style="margin-bottom: var(--spacing-lg);">
                                    <i class="fas fa-info-circle"></i>
                                    You have not set a local password specifically for this site because you utilize an
                                    external login. You can set one here.
                                </div>
                            }

                            <div class="form-group">
                                <label asp-for="ChangePasswordInput.NewPassword" class="form-label">New Password</label>
                                <div class="input-icon-wrapper">
                                    <i class="fas fa-lock input-icon"></i>
                                    <input asp-for="ChangePasswordInput.NewPassword" class="form-input" />
                                </div>
                                <span asp-validation-for="ChangePasswordInput.NewPassword" class="form-error"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ChangePasswordInput.ConfirmPassword" class="form-label">Confirm New
                                    Password</label>
                                <div class="input-icon-wrapper">
                                    <i class="fas fa-check-circle input-icon"></i>
                                    <input asp-for="ChangePasswordInput.ConfirmPassword" class="form-input" />
                                </div>
                                <span asp-validation-for="ChangePasswordInput.ConfirmPassword"
                                    class="form-error"></span>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i>
                                @(Model.HasPassword ? "Change Password" : "Set Password")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Tab switching
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                if (this.getAttribute('title') === 'Coming soon') return;

                // Update active tab button
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                // Update active content
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                const tabId = this.getAttribute('data-tab') + '-tab';
                document.getElementById(tabId).classList.add('active');
            });
        });

        // Avatar preview update
        const avatarInput = document.getElementById('avatar-url-input');
        const avatarPreview = document.getElementById('avatar-preview');

        if (avatarInput && avatarPreview) {
            avatarInput.addEventListener('input', function () {
                const url = this.value.trim();
                if (url) {
                    avatarPreview.src = url;
                } else {
                    avatarPreview.src = '/images/default-avatar.png';
                }
            });

            // Handle image load errors
            avatarPreview.addEventListener('error', function () {
                this.src = '/images/default-avatar.png';
            });
        }

        // File upload handling
        const fileInput = document.getElementById('avatar-file-input');
        const fileInfo = document.getElementById('file-info');

        if (fileInput && fileInfo && avatarPreview) {
            fileInput.addEventListener('change', function () {
                const file = this.files[0];

                if (file) {
                    // Validate file size (5MB)
                    if (file.size > 5 * 1024 * 1024) {
                        alert('File size must be less than 5MB');
                        this.value = '';
                        return;
                    }

                    // Validate file type
                    const allowedTypes = ['image/jpeg', 'image/png', 'image/gif'];
                    if (!allowedTypes.includes(file.type)) {
                        alert('Only JPG, PNG, and GIF images are allowed');
                        this.value = '';
                        return;
                    }

                    // Update file info display
                    const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
                    fileInfo.textContent = `${file.name} (${sizeMB}MB)`;
                    fileInfo.style.color = 'var(--color-success)';

                    // Preview image
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        avatarPreview.src = e.target.result;
                    };
                    reader.readAsDataURL(file);
                } else {
                    fileInfo.textContent = 'JPG, PNG, or GIF (max 5MB)';
                    fileInfo.style.color = '';
                }
            });
        }
    </script>
}

<style>
    .settings-page {
        max-width: 800px;
        margin: 0 auto;
        padding: var(--spacing-2xl) var(--spacing-lg);
    }

    .settings-container {
        width: 100%;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: var(--spacing-xl);
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .alert-success {
        background: linear-gradient(135deg, #10b98120, #059669);
        border-left: 4px solid var(--color-success);
        padding: var(--spacing-md) var(--spacing-lg);
        border-radius: var(--radius-lg);
        margin-bottom: var(--spacing-xl);
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
        color: var(--color-success);
        font-weight: 500;
        animation: slideDown 0.3s ease;
    }

    .settings-card {
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    .settings-tabs {
        display: flex;
        gap: var(--spacing-sm);
        padding: var(--spacing-lg);
        border-bottom: 2px solid var(--color-border);
        background: var(--color-bg);
    }

    .tab-btn {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-lg);
        background: transparent;
        border: 2px solid transparent;
        border-radius: var(--radius-lg);
        color: var(--color-text-secondary);
        font-weight: 600;
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .tab-btn:hover {
        background: var(--color-bg-hover);
        color: var(--color-text);
    }

    .tab-btn.active {
        background: var(--gradient-primary);
        color: white;
        border-color: transparent;
        box-shadow: var(--shadow-sm);
    }

    .tab-btn[title="Coming soon"] {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .tab-content {
        display: none;
        animation: fadeIn 0.3s ease;
    }

    .tab-content.active {
        display: block;
    }

    .avatar-section {
        display: flex;
        align-items: center;
        gap: var(--spacing-xl);
        padding: var(--spacing-xl);
        background: var(--color-bg);
        border-radius: var(--radius-lg);
        margin-bottom: var(--spacing-2xl);
    }

    .avatar-preview {
        position: relative;
        width: 120px;
        height: 120px;
        border-radius: var(--radius-full);
        overflow: hidden;
        border: 4px solid var(--color-border);
        flex-shrink: 0;
    }

    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity var(--transition-fast);
    }

    .avatar-preview:hover .avatar-overlay {
        opacity: 1;
    }

    .avatar-overlay i {
        color: white;
        font-size: 1.5rem;
    }

    .avatar-upload-zone {
        flex: 1;
    }

    .avatar-upload-zone h3 {
        font-size: 1.125rem;
        font-weight: 700;
        margin-bottom: var(--spacing-md);
    }

    .upload-options {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .upload-file-wrapper {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-sm);
    }

    .file-input-hidden {
        display: none;
    }

    .upload-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-md) var(--spacing-xl);
        background: var(--gradient-primary);
        color: white;
        border-radius: var(--radius-lg);
        font-weight: 600;
        cursor: pointer;
        transition: all var(--transition-fast);
        box-shadow: var(--shadow-sm);
        width: fit-content;
    }

    .upload-btn:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .file-info {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        transition: color var(--transition-fast);
    }

    .or-divider {
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
        margin: var(--spacing-sm) 0;
    }

    .or-divider::before,
    .or-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--color-border);
    }

    .or-divider span {
        color: var(--color-text-muted);
        font-size: 0.875rem;
        font-weight: 600;
    }

    .form-section {
        padding: var(--spacing-xl);
        border-bottom: 1px solid var(--color-border);
    }

    .form-section:last-of-type {
        border-bottom: none;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: var(--spacing-xl);
        color: var(--color-text);
    }

    .section-title i {
        color: var(--color-primary);
    }

    .form-group {
        margin-bottom: var(--spacing-lg);
    }

    .form-label {
        display: block;
        font-weight: 600;
        margin-bottom: var(--spacing-sm);
        color: var(--color-text);
        font-size: 0.9375rem;
    }

    .form-input,
    .form-textarea {
        width: 100%;
        padding: var(--spacing-md);
        background: var(--color-bg);
        border: 2px solid var(--color-border);
        border-radius: var(--radius-lg);
        color: var(--color-text);
        font-size: 0.9375rem;
        transition: all var(--transition-fast);
    }

    .form-input:focus,
    .form-textarea:focus {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    .form-textarea {
        resize: vertical;
        min-height: 100px;
        font-family: inherit;
    }

    .input-icon-wrapper {
        position: relative;
    }

    .input-icon-wrapper .form-input {
        padding-left: calc(var(--spacing-md) + 24px + var(--spacing-sm));
    }

    .input-icon {
        position: absolute;
        left: var(--spacing-md);
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-text-muted);
        width: 20px;
        text-align: center;
    }

    .form-hint {
        margin-top: var(--spacing-xs);
        font-size: 0.8125rem;
        color: var(--color-text-muted);
    }

    .form-error {
        display: block;
        margin-top: var(--spacing-xs);
        color: var(--color-danger);
        font-size: 0.8125rem;
    }

    .validation-errors {
        background: #fee;
        border-left: 4px solid var(--color-danger);
        padding: var(--spacing-md);
        border-radius: var(--radius-lg);
        margin-bottom: var(--spacing-lg);
        color: var(--color-danger);
    }

    .form-actions {
        display: flex;
        gap: var(--spacing-md);
        justify-content: flex-end;
        padding: var(--spacing-xl);
        background: var(--color-bg);
        border-top: 1px solid var(--color-border);
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-md) var(--spacing-xl);
        border-radius: var(--radius-lg);
        font-weight: 600;
        font-size: 0.9375rem;
        cursor: pointer;
        transition: all var(--transition-fast);
        border: 2px solid transparent;
    }

    .btn-primary {
        background: var(--gradient-primary);
        color: white;
        border-color: transparent;
        box-shadow: var(--shadow-sm);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .btn-outline {
        background: transparent;
        color: var(--color-text);
        border-color: var(--color-border);
    }

    .btn-outline:hover {
        background: var(--color-bg-hover);
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .settings-page {
            padding: var(--spacing-lg) var(--spacing-md);
        }

        .avatar-section {
            flex-direction: column;
            text-align: center;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
