@page
@model Blog.Web.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-5">
                    @if (Model.ResetSuccessful)
                    {
                        <div class="text-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor"
                                class="bi bi-check-circle-fill text-success mb-3" viewBox="0 0 16 16">
                                <path
                                    d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                            </svg>
                            <h2 class="text-success mb-3">Password Reset!</h2>
                            <p class="lead">@Model.StatusMessage</p>
                            <a href="/Account/Login" class="btn btn-primary btn-lg mt-3">Sign In</a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                                class="bi bi-shield-lock text-primary mb-3" viewBox="0 0 16 16">
                                <path
                                    d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025q.114-.034.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56" />
                                <path
                                    d="M9.5 6.5a1.5 1.5 0 0 1-1 1.415l.385 1.99a.5.5 0 0 1-.491.595h-.788a.5.5 0 0 1-.49-.595l.384-1.99a1.5 1.5 0 1 1 2-1.415" />
                            </svg>
                            <h2>Reset Your Password</h2>
                            <p class="text-muted">Enter your email and new password.</p>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.StatusMessage) && !Model.ResetSuccessful)
                        {
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-circle"></i>
                                @Model.StatusMessage
                            </div>
                        }

                        <form method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Code" value="@Model.Code" />

                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label">Email Address</label>
                                <input asp-for="Input.Email" class="form-control" type="email"
                                    placeholder="you@example.com" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label">New Password</label>
                                <input asp-for="Input.Password" class="form-control" type="password"
                                    placeholder="••••••••" />
                                <small class="form-text text-muted">At least 8 characters with uppercase, lowercase, and
                                    number</small>
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                                <input asp-for="Input.ConfirmPassword" class="form-control" type="password"
                                    placeholder="••••••••" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mb-3">Reset Password</button>

                            <div class="text-center">
                                <a href="/Account/Login" class="text-decoration-none">Back to Login</a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
