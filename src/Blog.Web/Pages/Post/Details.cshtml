@page "{slug}"
@model Blog.Web.Pages.Post.DetailsModel
@{
    ViewData["Title"] = Model.Post?.Title ?? "Post Not Found";
    ViewData["MetaDescription"] = Model.Post?.MetaDescription ?? Model.Post?.Excerpt;
    ViewData["MetaKeywords"] = Model.Post?.MetaKeywords;
    ViewData["OgImage"] = Model.Post?.CoverImageUrl;
}

@if (Model.Post == null)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔍</div>
        <h3 class="empty-state-title">Post not found</h3>
        <p class="empty-state-description">The post you're looking for doesn't exist or has been removed.</p>
        <a href="/" class="btn btn-primary">Go Home</a>
    </div>
}
else
{
    <div id="reading-progress" class="reading-progress"></div>
    
    <article class="post-detail">
        @if (!string.IsNullOrEmpty(Model.Post.CoverImageUrl))
        {
            <div class="post-cover">
                <img src="@Model.Post.CoverImageUrl" alt="@Model.Post.Title" />
            </div>
        }

        <header class="post-header">
            <div class="post-tags">
                @foreach (var tag in Model.Post.Tags)
                {
                    <a href="/Tag/@tag.Slug" class="tag"
                       style="@(tag.Color != null ? $"background: {tag.Color}20; color: {tag.Color};" : "")">
                        #@tag.Name
                    </a>
                }
            </div>

            <h1 class="post-title">@Model.Post.Title</h1>

            <div class="post-meta">
                <a href="/Author/@Model.Post.Author.UserName" class="post-author">
                    <img src="@(Model.Post.Author.AvatarUrl ?? "/images/default-avatar.png")" 
                         alt="@Model.Post.Author.DisplayName" class="author-avatar" />
                    <div class="author-info">
                        <span class="author-name">@(Model.Post.Author.DisplayName ?? Model.Post.Author.UserName)</span>
                        <span class="post-date">
                            Published @Model.Post.PublishedAt?.ToString("MMMM dd, yyyy") · @Model.Post.ReadingTimeMinutes min read
                        </span>
                    </div>
                </a>
            </div>
        </header>

        <div class="post-content markdown-content">
            @Html.Raw(Model.Post.RenderedContent)
        </div>

        <footer class="post-footer">
            <div class="post-actions">
                <form method="post" asp-page-handler="Like" class="inline-form" id="like-form" data-slug="@Model.Post.Slug">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="action-btn @(Model.Post.IsLiked ? "active" : "")" id="like-btn">
                        <i class="@(Model.Post.IsLiked ? "fas" : "far") fa-heart" id="like-icon"></i>
                        <span id="like-count">@Model.Post.LikeCount</span>
                    </button>
                </form>
                
                <button type="button" class="action-btn" onclick="document.getElementById('comments').scrollIntoView({behavior: 'smooth'})">
                    <i class="far fa-comment"></i>
                    <span>@Model.Post.CommentCount</span>
                </button>
                
                <form method="post" asp-page-handler="Bookmark" class="inline-form" id="bookmark-form" data-slug="@Model.Post.Slug">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="action-btn @(Model.Post.IsBookmarked ? "active" : "")" id="bookmark-btn">
                        <i class="@(Model.Post.IsBookmarked ? "fas" : "far") fa-bookmark" id="bookmark-icon"></i>
                    </button>
                </form>
                
                <button type="button" class="action-btn" onclick="copyToClipboard(window.location.href, this)">
                    <i class="far fa-share-square"></i>
                </button>
            </div>
        </footer>
    </article>

    <!-- Comments Section -->
    <section id="comments" class="comments-section">
        <h2 class="section-title">Comments (@Model.Comments.Count)</h2>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form method="post" asp-page-handler="Comment" class="comment-form card">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <textarea name="content" class="form-textarea" placeholder="Write a comment..." required></textarea>
                    <button type="submit" class="btn btn-primary mt-2">Post Comment</button>
                </div>
            </form>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center">
                    <p>Please <a href="/Account/Login?returnUrl=@HttpContext.Request.Path">sign in</a> to leave a comment.</p>
                </div>
            </div>
        }

        <div class="comments-list">
            @foreach (var comment in Model.Comments)
            {
                <div class="comment-item card" id="comment-@comment.Id">
                    <div class="card-body">
                        <div class="comment-header">
                            <a href="/Author/@comment.Author.UserName" class="comment-author">
                                <img src="@(comment.Author.AvatarUrl ?? "/images/default-avatar.png")" alt="" class="comment-avatar" />
                                <span class="comment-author-name">@(comment.Author.DisplayName ?? comment.Author.UserName)</span>
                            </a>
                            <span class="comment-date">@comment.CreatedAt.ToString("MMM dd, yyyy")</span>
                            @if (comment.IsEdited)
                            {
                                <span class="comment-edited">(edited)</span>
                            }
                        </div>
                        <div class="comment-content markdown-content">
                            @Html.Raw(comment.RenderedContent ?? comment.Content)
                        </div>
                        
                        <!-- Replies -->
                        @if (comment.Replies.Any())
                        {
                            <div class="comment-replies">
                                @foreach (var reply in comment.Replies)
                                {
                                    <div class="comment-item reply" id="comment-@reply.Id">
                                        <div class="comment-header">
                                            <a href="/Author/@reply.Author.UserName" class="comment-author">
                                                <img src="@(reply.Author.AvatarUrl ?? "/images/default-avatar.png")" alt="" class="comment-avatar" />
                                                <span class="comment-author-name">@(reply.Author.DisplayName ?? reply.Author.UserName)</span>
                                            </a>
                                            <span class="comment-date">@reply.CreatedAt.ToString("MMM dd, yyyy")</span>
                                        </div>
                                        <div class="comment-content">@Html.Raw(reply.RenderedContent ?? reply.Content)</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>
}

@section Scripts {
    <script src="~/js/post-interactions.js" asp-append-version="true"></script>
}

<style>
    .reading-progress {
        position: fixed;
        top: 64px;
        left: 0;
        height: 3px;
        background: var(--gradient-primary);
        z-index: 1000;
        width: 0%;
        transition: width 0.1s ease;
    }
    .post-detail {
        max-width: 800px;
        margin: 0 auto;
    }
    .post-cover {
        margin: 0 -1rem var(--spacing-xl);
        border-radius: var(--radius-xl);
        overflow: hidden;
    }
    .post-cover img {
        width: 100%;
        height: auto;
        max-height: 400px;
        object-fit: cover;
    }
    .post-header {
        margin-bottom: var(--spacing-2xl);
    }
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-xs);
        margin-bottom: var(--spacing-md);
    }
    .post-title {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: var(--spacing-lg);
    }
    .post-meta {
        display: flex;
        align-items: center;
    }
    .post-author {
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
        color: var(--color-text);
    }
    .post-author:hover .author-name {
        color: var(--color-primary);
    }
    .author-avatar {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-full);
    }
    .author-info {
        display: flex;
        flex-direction: column;
    }
    .author-name {
        font-weight: 600;
    }
    .post-date {
        font-size: 0.875rem;
        color: var(--color-text-muted);
    }
    .post-content {
        margin-bottom: var(--spacing-2xl);
    }
    .post-footer {
        padding: var(--spacing-lg) 0;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        margin-bottom: var(--spacing-2xl);
    }
    .post-actions {
        display: flex;
        gap: var(--spacing-md);
    }
    .inline-form {
        display: inline;
    }
    .action-btn {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-md);
        background: var(--color-bg);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-full);
        color: var(--color-text-secondary);
        font-size: 0.9375rem;
        cursor: pointer;
        transition: all var(--transition-fast);
    }
    .action-btn:hover {
        background: var(--color-bg-hover);
        color: var(--color-text);
    }
    .action-btn.active {
        color: var(--color-danger);
        border-color: var(--color-danger);
    }
    .action-btn.active i {
        color: var(--color-danger);
    }
    .comments-section {
        max-width: 800px;
        margin: 0 auto;
    }
    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: var(--spacing-lg);
    }
    .comment-form {
        margin-bottom: var(--spacing-xl);
    }
    .comments-list {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }
    .comment-header {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-sm);
    }
    .comment-author {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        color: var(--color-text);
    }
    .comment-avatar {
        width: 32px;
        height: 32px;
        border-radius: var(--radius-full);
    }
    .comment-author-name {
        font-weight: 500;
    }
    .comment-date {
        font-size: 0.75rem;
        color: var(--color-text-muted);
    }
    .comment-edited {
        font-size: 0.75rem;
        color: var(--color-text-muted);
        font-style: italic;
    }
    .comment-content {
        font-size: 0.9375rem;
        line-height: 1.6;
    }
    .comment-replies {
        margin-top: var(--spacing-md);
        padding-left: var(--spacing-xl);
        border-left: 2px solid var(--color-border);
    }
    .comment-replies .comment-item.reply {
        background: transparent;
        border: none;
        padding: var(--spacing-sm) 0;
    }
</style>
