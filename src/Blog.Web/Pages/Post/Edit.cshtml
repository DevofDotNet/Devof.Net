@page "/post/edit/{slug?}"
@model Blog.Web.Pages.Post.EditModel
@{
    ViewData["Title"] = "Edit Post";
}

<div class="editor-container">
    <form method="post" class="editor-form" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PostId" />

        <div class="editor-header">
            <h1>Edit post</h1>
            <div class="editor-actions">
                <a href="/Post/@Model.CurrentSlug" class="btn btn-outline">
                    <i class="fas fa-eye"></i> View Post
                </a>
                <button type="submit" name="publish" value="false" class="btn btn-outline">
                    <i class="fas fa-save"></i> Save Draft
                </button>
                <button type="submit" name="publish" value="true" class="btn btn-primary">
                    <i class="fas fa-paper-plane"></i> Update & Publish
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                @Model.ErrorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                @Model.SuccessMessage
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>Please fix the following errors:</strong>
                <ul style="margin: 0.5rem 0 0 1.5rem;">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <div class="editor-main card">
            <div class="card-body">
                <!-- Cover Image -->
                <div class="cover-upload">
                    <input type="file" name="coverImage" id="coverImage" accept="image/*" class="hidden" />
                    @if (!string.IsNullOrEmpty(Model.Input.CoverImageUrl))
                    {
                        <div id="coverPreview" class="cover-preview">
                            <img src="@Model.Input.CoverImageUrl" alt="Current cover" />
                        </div>
                        <label for="coverImage" class="cover-upload-label small">
                            <i class="fas fa-image"></i>
                            <span>Change cover image</span>
                        </label>
                    }
                    else
                    {
                        <label for="coverImage" class="cover-upload-label">
                            <i class="fas fa-image"></i>
                            <span>Add a cover image</span>
                        </label>
                        <div id="coverPreview" class="cover-preview"></div>
                    }
                </div>

                <!-- Title -->
                <div class="form-group">
                    <input type="text" asp-for="Input.Title" class="editor-title-input" placeholder="Post title..."
                        maxlength="200" required />
                    <span asp-validation-for="Input.Title" class="form-error"></span>
                </div>

                <!-- Tags -->
                <div class="form-group">
                    <input type="text" asp-for="TagsInput" class="tags-input"
                        placeholder="Add up to 5 tags (comma separated)..." />
                    <span class="form-help">Example: csharp, dotnet, tutorial</span>
                </div>

                <!-- Content Editor -->
                <div class="form-group">
                    <div class="editor-tabs">
                        <button type="button" class="editor-tab active" data-tab="write">Write</button>
                        <button type="button" class="editor-tab" data-tab="preview">Preview</button>
                    </div>
                    <div class="editor-content">
                        <div id="write-panel" class="editor-panel active">
                            <textarea asp-for="Input.Content" class="editor-textarea"
                                placeholder="Write your post content here... (Markdown supported)" required></textarea>
                        </div>
                        <div id="preview-panel" class="editor-panel markdown-content">
                            <p class="text-muted">Preview will appear here...</p>
                        </div>
                    </div>
                    <span asp-validation-for="Input.Content" class="form-error"></span>
                    <p class="form-hint">Minimum 50 characters required. Markdown formatting is supported.</p>
                </div>
            </div>
        </div>

        <!-- SEO Settings -->
        <details class="seo-settings card">
            <summary class="card-header">
                <i class="fas fa-search"></i> SEO Settings (optional)
            </summary>
            <div class="card-body">
                <div class="form-group">
                    <label asp-for="Input.MetaTitle" class="form-label">Meta Title</label>
                    <input type="text" asp-for="Input.MetaTitle" class="form-input" maxlength="200" />
                </div>
                <div class="form-group">
                    <label asp-for="Input.MetaDescription" class="form-label">Meta Description</label>
                    <textarea asp-for="Input.MetaDescription" class="form-textarea" rows="2" maxlength="500"></textarea>
                </div>
                <div class="form-group">
                    <label asp-for="Input.MetaKeywords" class="form-label">Keywords</label>
                    <input type="text" asp-for="Input.MetaKeywords" class="form-input"
                        placeholder="keyword1, keyword2, keyword3" maxlength="300" />
                </div>
            </div>
        </details>

        <!-- Danger Zone -->
        <details class="danger-zone card">
            <summary class="card-header text-danger">
                <i class="fas fa-exclamation-triangle"></i> Danger Zone
            </summary>
            <div class="card-body">
                <p class="text-muted">Deleting a post is permanent and cannot be undone.</p>
                <button type="submit" asp-page-handler="Delete" class="btn btn-danger"
                    onclick="return confirm('Are you sure you want to delete this post? This action cannot be undone.');">
                    <i class="fas fa-trash"></i> Delete Post
                </button>
            </div>
        </details>
    </form>
</div>

<style>
    .editor-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .editor-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--spacing-xl);
        flex-wrap: wrap;
        gap: var(--spacing-md);
    }

    .editor-header h1 {
        font-size: 1.5rem;
        font-weight: 700;
    }

    .editor-actions {
        display: flex;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
    }

    .cover-upload {
        margin-bottom: var(--spacing-lg);
    }

    .cover-upload .hidden {
        display: none;
    }

    .cover-upload-label {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-md) var(--spacing-lg);
        border: 2px dashed var(--color-border);
        border-radius: var(--radius-lg);
        color: var(--color-text-muted);
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .cover-upload-label.small {
        padding: var(--spacing-sm) var(--spacing-md);
        font-size: 0.875rem;
        margin-top: var(--spacing-sm);
    }

    .cover-upload-label:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .cover-preview {
        margin-top: var(--spacing-md);
    }

    .cover-preview img {
        max-height: 200px;
        border-radius: var(--radius-lg);
    }

    .editor-title-input {
        width: 100%;
        padding: var(--spacing-md) 0;
        font-size: 2rem;
        font-weight: 700;
        border: none;
        background: transparent;
        color: var(--color-text);
        outline: none;
    }

    .editor-title-input::placeholder {
        color: var(--color-text-muted);
    }

    .tags-input {
        width: 100%;
        padding: var(--spacing-sm) 0;
        font-size: 1rem;
        border: none;
        background: transparent;
        color: var(--color-text);
        outline: none;
    }

    .editor-tabs {
        display: flex;
        gap: var(--spacing-xs);
        padding: var(--spacing-sm);
        background: var(--color-bg);
        border-radius: var(--radius-md);
        margin-bottom: var(--spacing-md);
    }

    .editor-tab {
        padding: var(--spacing-sm) var(--spacing-md);
        background: none;
        border: none;
        color: var(--color-text-secondary);
        cursor: pointer;
        border-radius: var(--radius-sm);
        font-weight: 500;
        transition: all var(--transition-fast);
    }

    .editor-tab:hover {
        color: var(--color-text);
    }

    .editor-tab.active {
        background: var(--color-bg-elevated);
        color: var(--color-primary);
        box-shadow: var(--shadow-sm);
    }

    .editor-panel {
        display: none;
    }

    .editor-panel.active {
        display: block;
    }

    .editor-textarea {
        width: 100%;
        min-height: 400px;
        padding: var(--spacing-md);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        font-family: var(--font-mono);
        font-size: 0.9375rem;
        line-height: 1.6;
        resize: vertical;
        background: var(--color-bg);
        color: var(--color-text);
    }

    .editor-textarea:focus {
        outline: none;
        border-color: var(--color-primary);
    }

    .seo-settings,
    .danger-zone {
        margin-top: var(--spacing-lg);
    }

    .seo-settings summary,
    .danger-zone summary {
        cursor: pointer;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .alert-danger {
        background: #fee2e2;
        border-left: 4px solid #ef4444;
        padding: var(--spacing-md) var(--spacing-lg);
        border-radius: var(--radius-lg);
        margin-bottom: var(--spacing-lg);
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: var(--spacing-sm);
        color: #dc2626;
    }

    .alert-success {
        background: #d1fae5;
        border-left: 4px solid #10b981;
        padding: var(--spacing-md) var(--spacing-lg);
        border-radius: var(--radius-lg);
        margin-bottom: var(--spacing-lg);
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        color: #059669;
    }

    .form-error {
        display: block;
        color: #dc2626;
        font-size: 0.8125rem;
        margin-top: var(--spacing-xs);
    }

    .form-hint {
        font-size: 0.8125rem;
        color: var(--color-text-muted);
        margin-top: var(--spacing-xs);
    }

    .text-danger {
        color: #dc2626;
    }

    .btn-danger {
        background: #ef4444;
        color: white;
        border: none;
    }

    .btn-danger:hover {
        background: #dc2626;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        // Tab switching
        document.querySelectorAll('.editor-tab').forEach(tab => {
            tab.addEventListener('click', function () {
                document.querySelectorAll('.editor-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.editor-panel').forEach(p => p.classList.remove('active'));

                this.classList.add('active');
                const panel = document.getElementById(this.dataset.tab + '-panel');
                panel.classList.add('active');

                if (this.dataset.tab === 'preview') {
                    const content = document.querySelector('.editor-textarea').value;
                    panel.innerHTML = marked.parse(content) || '<p class="text-muted">Preview will appear here...</p>';
                }
            });
        });

        // Cover image preview
        document.getElementById('coverImage').addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('coverPreview').innerHTML =
                        `<img src="${e.target.result}" alt="Cover preview" />`;
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
